# Intelligent Document Extraction System — Docker image
FROM python:3.11-slim

# System dependencies: Tesseract OCR engine + libs needed by OpenCV
RUN apt-get update && apt-get install -y --no-install-recommends \
    tesseract-ocr \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Hugging Face Spaces requires the container to listen on 7860 by default.
# Override with -e PORT=8501 (or via docker-compose) for other platforms.
ENV PORT=7860

# Install Python dependencies first (better Docker layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

EXPOSE 8501
EXPOSE 7860

# Basic container healthcheck so `docker ps` shows health status
HEALTHCHECK CMD curl --fail http://localhost:${PORT:-8501}/_stcore/health || exit 1

ENTRYPOINT ["sh", "-c", "streamlit run app.py --server.port=${PORT:-8501} --server.address=0.0.0.0 --server.headless=true"]